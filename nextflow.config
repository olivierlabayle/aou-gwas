process {
    container = "us-central1-docker.pkg.dev/all-of-us-rw-prod/aou-rw-gar-remote-repo-docker-prod/aou-gwas:main"
}

profiles {
    'google-batch' {

        // Google Batch config
        process.executor = 'google-batch'
        // Edit the following line for your bucket resource
        // Use a unique name for each run to avoid cluttering results. Here, we append /output1
        workDir = "gs://cloud-storage-critical-illness-wb-helpful-coffee-2299/nextflow-files/work"

        google.region  = env('PROJECT_DEFAULT_REGION')
        google.project = env('GOOGLE_CLOUD_PROJECT')

        google.batch.serviceAccountEmail = env('GOOGLE_SERVICE_ACCOUNT_EMAIL')
        google.batch.usePrivateAddress = true
        google.batch.network = 'global/networks/network'
        google.batch.subnetwork = "regions/${env('PROJECT_DEFAULT_REGION')}/subnetworks/subnetwork"
    }
}
